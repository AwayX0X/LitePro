function Global-Optimize {
    Write-Host "`n[+] Initializing Advanced Gaming Optimization Stack..." -ForegroundColor Cyan
    Start-Sleep -Milliseconds 500

    # 1. NETWORK & GPEDIT UNLIMIT (QoS Packet Scheduler)
    Write-Host "[>] Unlimiting Bandwidth & Tuning TCP Network Stack..." -ForegroundColor White
    $QosPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Psched"
    if (-not (Test-Path $QosPath)) { New-Item -Path $QosPath -Force | Out-Null }
    New-ItemProperty -Path $QosPath -Name "NonBestEffortLimit" -Value 0 -PropertyType DWord -Force | Out-Null

    netsh int tcp set global congestionprovider=bbr | Out-Null
    netsh int tcp set global autotuninglevel=normal | Out-Null
    netsh int tcp set global ecncapability=enabled | Out-Null
    netsh int tcp set global timestamps=disabled | Out-Null
    netsh int tcp set global rss=enabled | Out-Null
    netsh int tcp set global rsc=enabled | Out-Null
    netsh int tcp set global dca=enabled | Out-Null
    netsh int tcp set global netdma=enabled | Out-Null

    # 2. NETWORK ADAPTER LATENCY STRIPPING
    Write-Host "[>] Stripping Power-Saving Delays from LAN Controller..." -ForegroundColor White
    $LANPaths = Get-ChildItem -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Class\{4d36e972-e325-11ce-bfc1-08002be10318}" -ErrorAction SilentlyContinue
    foreach ($lan in $LANPaths) {
        $path = $lan.PSPath
        if (Get-ItemProperty -Path $path -Name "DriverDesc" -ErrorAction SilentlyContinue) {
            New-ItemProperty -Path $path -Name "*EEELinkAdvertisement" -Value 0 -PropertyType String -Force -ErrorAction SilentlyContinue | Out-Null
            New-ItemProperty -Path $path -Name "*EnergyEfficientEthernet" -Value 0 -PropertyType String -Force -ErrorAction SilentlyContinue | Out-Null
            New-ItemProperty -Path $path -Name "*GreenEthernet" -Value 0 -PropertyType String -Force -ErrorAction SilentlyContinue | Out-Null
            New-ItemProperty -Path $path -Name "PowerDownPll" -Value 0 -PropertyType String -Force -ErrorAction SilentlyContinue | Out-Null
        }
    }

    # 3. MOUSE & KEYBOARD LATENCY TWEAKS
    Write-Host "[>] Decreasing Mouse & Keyboard Hardware Input Buffers..." -ForegroundColor White
    $MousePath = "HKCU:\Control Panel\Mouse"
    New-ItemProperty -Path $MousePath -Name "MouseSpeed" -Value "0" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path $MousePath -Name "MouseThreshold1" -Value "0" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path $MousePath -Name "MouseThreshold2" -Value "0" -PropertyType String -Force | Out-Null

    $KeyPath = "HKCU:\Control Panel\Accessibility\Keyboard Response"
    if (-not (Test-Path $KeyPath)) { New-Item -Path $KeyPath -Force | Out-Null }
    New-ItemProperty -Path "HKCU:\Control Panel\Keyboard" -Name "KeyboardDelay" -Value "0" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path "HKCU:\Control Panel\Keyboard" -Name "KeyboardSpeed" -Value "31" -PropertyType String -Force | Out-Null

    $PriorityPath = "HKLM:\SYSTEM\CurrentControlSet\Control\PriorityControl"
    New-ItemProperty -Path $PriorityPath -Name "Win32PrioritySeparation" -Value 26 -PropertyType DWord -Force | Out-Null

    # 4. MSI MODE ACTIVATION (GPU Express Lane Force)
    Write-Host "[>] Transforming GPU Interrupt Priority Interface to MSI Mode..." -ForegroundColor White
    $VideoControllers = Get-ChildItem -Path "HKLM:\SYSTEM\CurrentControlSet\Enum\PCI" -Recurse -ErrorAction SilentlyContinue | Where-Object { $_.PSChildName -eq "Device Parameters" }
    foreach ($vc in $VideoControllers) {
        $msiPath = "$($vc.PSPath)\Interrupt Management\MessageSignaledInterruptProperties"
        if (Test-Path "$($vc.PSPath)\Interrupt Management") {
            if (-not (Test-Path $msiPath)) { New-Item -Path $msiPath -Force | Out-Null }
            New-ItemProperty -Path $msiPath -Name "MSISupported" -Value 1 -PropertyType DWord -Force | Out-Null
            New-ItemProperty -Path $msiPath -Name "MessageNumberLimit" -Value 1 -PropertyType DWord -Force | Out-Null
        }
    }

    # 5. DYNAMIC BCDOS PERFORMANCE TWEAKS
    Write-Host "[>] Adjusting BCD System Clock Constants for Micro-Stutter Fix..." -ForegroundColor White
    bcdedit /set useplatformclock false | Out-Null
    bcdedit /set disabledynamictick yes | Out-Null

    # 6. WINDOWS TELEMETRY & BLOATWARE SILENCER
    Write-Host "[>] Killing Windows Background Telemetry Reporting Processes..." -ForegroundColor White
    Stop-Service -Name "DiagTrack" -ErrorAction SilentlyContinue
    Set-Service -Name "DiagTrack" -StartupType Disabled -ErrorAction SilentlyContinue
    $TelemetryPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection"
    if (-not (Test-Path $TelemetryPath)) { New-Item -Path $TelemetryPath -Force | Out-Null }
    New-ItemProperty -Path $TelemetryPath -Name "AllowTelemetry" -Value 0 -PropertyType DWord -Force | Out-Null

    # 7. PREMIUM GENERAL FPS BOOST & GAMEDVR OFF
    Write-Host "[>] Elevating Game Thread Scheduling parameters..." -ForegroundColor White
    $SysProfilePath = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile"
    New-ItemProperty -Path $SysProfilePath -Name "NetworkThrottlingIndex" -Value 0xffffffff -PropertyType DWord -Force | Out-Null
    New-ItemProperty -Path $SysProfilePath -Name "SystemResponsiveness" -Value 0 -PropertyType DWord -Force | Out-Null

    $GamesProfilePath = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games"
    if (Test-Path $GamesProfilePath) {
        New-ItemProperty -Path $GamesProfilePath -Name "GPU Priority" -Value 8 -PropertyType DWord -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "Priority" -Value 6 -PropertyType DWord -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "Scheduling Category" -Value "High" -PropertyType String -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "SFIO Priority" -Value "High" -PropertyType String -Force | Out-Null
    }
    New-ItemProperty -Path "HKCU:\System\GameConfigStore" -Name "GameDVR_Enabled" -Value 0 -PropertyType DWord -Force | Out-Null
    powercfg /h off | Out-Null

    # 8. EXTREME FIVEM CPU KERNEL INJECTIONS
    Write-Host "[>] Locking FiveM Process Scheduling Matrix into High Priority..." -ForegroundColor Green
    $FiveMProcesses = @("FiveM.exe", "FiveM_GTAProcess.exe", "FiveM_b2699_GTAProcess.exe", "FiveM_b3095_GTAProcess.exe", "FiveM_b3258_GTAProcess.exe", "GTA5.exe")
    foreach ($proc in $FiveMProcesses) {
        $RegistryIFEOPath = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options\$proc"
        if (-not (Test-Path $RegistryIFEOPath)) { New-Item -Path $RegistryIFEOPath -Force | Out-Null }
        if (-not (Test-Path "$RegistryIFEOPath\PerfOptions")) { New-Item -Path "$RegistryIFEOPath\PerfOptions" -Force | Out-Null }
        New-ItemProperty -Path "$RegistryIFEOPath\PerfOptions" -Name "CpuPriorityClass" -Value 3 -PropertyType DWord -Force | Out-Null
    }

    $MemoryManagerPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management"
    New-ItemProperty -Path $MemoryManagerPath -Name "LargeSystemCache" -Value 1 -PropertyType DWord -Force | Out-Null
    New-ItemProperty -Path $MemoryManagerPath -Name "SystemPages" -Value 0xffffffff -PropertyType DWord -Force | Out-Null

    # 9. BACKGROUND AUTO-FLUSH RAM STANDBY CACHE (PATCHED PROPERLY)
    Write-Host "[>] Injecting 5-Min Scheduled Auto-RAM Engine (Fix Leak)..." -ForegroundColor Green
    $Action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -Command `"[System.GC]::Collect(); [System.GC]::WaitForPendingFinalizers();`""
    $Trigger = New-ScheduledTaskTrigger -AtLogOn
    $Trigger.Repetition.Interval = (New-TimeSpan -Minutes 5)
    $Settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable
    Register-ScheduledTask -TaskName "LitePro_Memory_AutoFlush" -Action $Action -Trigger $Trigger -Settings $Settings -User "SYSTEM" -Force | Out-Null

    # 10. DEEP STORAGE & POWERSHELL HISTORY JUNK CLEANER ENGINE
    Write-Host "[>] Purging Deep Storage Junk & PowerShell History..." -ForegroundColor Yellow
    
    # Target common Windows junk paths
    $JunkTargets = @(
        "$env:USERPROFILE\AppData\Local\Temp\*",
        "$env:SystemRoot\Temp\*",
        "$env:SystemRoot\Prefetch\*",
        "$env:SystemRoot\SoftwareDistribution\Download\*",
        "$env:LOCALAPPDATA\CrashDumps\*",
        "$env:ProgramData\Microsoft\Windows\WER\*"
    )
    foreach ($target in $JunkTargets) {
        Remove-Item -Path $target -Recurse -Force -ErrorAction SilentlyContinue | Out-Null
    }

    # 🔥 NEW: Clear PowerShell Console History File Data
    Clear-History -ErrorAction SilentlyContinue
    $HistoryPath = "$env:APPDATA\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"
    if (Test-Path $HistoryPath) {
        Clear-Content -Path $HistoryPath -ErrorAction SilentlyContinue
    }

    # Flush DNS Resolvers
    ipconfig /flushdns | Out-Null
    netsh int ip reset | Out-Null
    netsh winsock reset | Out-Null

    Write-Host "`n[-] ALL PERFORMANCE & DEEP CLEAN MODULES APPLIED!" -ForegroundColor Green
    Write-Host "[!] A System REBOOT is recommended to lock in all engine changes." -ForegroundColor Yellow
    Read-Host "`nPress Enter to return to Menu..."
}

