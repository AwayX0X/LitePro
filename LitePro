function Global-Rollback {
    Write-Host "`n[-] Commencing Factory Configuration Restoration..." -ForegroundColor Yellow
    Start-Sleep -Milliseconds 500

    Remove-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Psched" -Name "NonBestEffortLimit" -ErrorAction SilentlyContinue
    netsh int tcp set global congestionprovider=default | Out-Null
    netsh int tcp set global autotuninglevel=normal | Out-Null
    netsh int tcp set global ecncapability=default | Out-Null
    netsh int tcp set global timestamps=default | Out-Null
    
    # Restore Network LAN Controller parameters
    $LANPaths = Get-ChildItem -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Class\{4d36e972-e325-11ce-bfc1-08002be10318}" -ErrorAction SilentlyContinue
    foreach ($lan in $LANPaths) {
        $path = $lan.PSPath
        Remove-ItemProperty -Path $path -Name "*EEELinkAdvertisement" -ErrorAction SilentlyContinue
        Remove-ItemProperty -Path $path -Name "*EnergyEfficientEthernet" -ErrorAction SilentlyContinue
        Remove-ItemProperty -Path $path -Name "*GreenEthernet" -ErrorAction SilentlyContinue
        Remove-ItemProperty -Path $path -Name "PowerDownPll" -ErrorAction SilentlyContinue
    }

    # Restore Inputs
    $MousePath = "HKCU:\Control Panel\Mouse"
    New-ItemProperty -Path $MousePath -Name "MouseSpeed" -Value "1" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path $MousePath -Name "MouseThreshold1" -Value "6" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path $MousePath -Name "MouseThreshold2" -Value "10" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path "HKCU:\Control Panel\Keyboard" -Name "KeyboardDelay" -Value "1" -PropertyType String -Force | Out-Null
    New-ItemProperty -Path "HKCU:\Control Panel\Keyboard" -Name "KeyboardSpeed" -Value "31" -PropertyType String -Force | Out-Null

    # Restore BCD Constants
    bcdedit /deletevalue useplatformclock -ErrorAction SilentlyContinue | Out-Null
    bcdedit /deletevalue disabledynamictick -ErrorAction SilentlyContinue | Out-Null

    # Restore Telemetry Processing
    Set-Service -Name "DiagTrack" -StartupType Automatic -ErrorAction SilentlyContinue
    Remove-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection" -Name "AllowTelemetry" -ErrorAction SilentlyContinue

    # Restore Windows Scheduler Profiles
    $SysProfilePath = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile"
    New-ItemProperty -Path $SysProfilePath -Name "NetworkThrottlingIndex" -Value 10 -PropertyType DWord -Force | Out-Null
    New-ItemProperty -Path $SysProfilePath -Name "SystemResponsiveness" -Value 14 -PropertyType DWord -Force | Out-Null

    $GamesProfilePath = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games"
    if (Test-Path $GamesProfilePath) {
        New-ItemProperty -Path $GamesProfilePath -Name "GPU Priority" -Value 8 -PropertyType DWord -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "Priority" -Value 2 -PropertyType DWord -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "Scheduling Category" -Value "Medium" -PropertyType String -Force | Out-Null
        New-ItemProperty -Path $GamesProfilePath -Name "SFIO Priority" -Value "Normal" -PropertyType String -Force | Out-Null
    }

    $FiveMProcesses = @("FiveM.exe", "FiveM_GTAProcess.exe", "FiveM_b2699_GTAProcess.exe", "FiveM_b3095_GTAProcess.exe", "FiveM_b3258_GTAProcess.exe", "GTA5.exe")
    foreach ($proc in $FiveMProcesses) {
        Remove-Item -Path "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options\$proc" -Recurse -ErrorAction SilentlyContinue | Out-Null
    }

    $MemoryManagerPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management"
    New-ItemProperty -Path $MemoryManagerPath -Name "LargeSystemCache" -Value 0 -PropertyType DWord -Force | Out-Null
    New-ItemProperty -Path $MemoryManagerPath -Name "SystemPages" -Value 0 -PropertyType DWord -Force | Out-Null

    New-ItemProperty -Path "HKCU:\System\GameConfigStore" -Name "GameDVR_Enabled" -Value 1 -PropertyType DWord -Force | Out-Null

    if (Test-Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\QoS") {
        Remove-Item -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\QoS" -Recurse -Force -ErrorAction SilentlyContinue | Out-Null
    }

    # Delete Auto-Flush Background Task
    Unregister-ScheduledTask -TaskName "LitePro_Memory_AutoFlush" -Confirm:$false -ErrorAction SilentlyContinue | Out-Null

    powercfg /h on | Out-Null
    netsh int ip reset | Out-Null
    netsh winsock reset | Out-Null
    
    Write-Host "`n[+] ROLLBACK RUN COMPLETE: Factory defaults restored." -ForegroundColor Green
    Read-Host "`nPress Enter to return to Menu..."
}

